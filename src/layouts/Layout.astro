---
interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = 'Cincinnati mobile notary that comes to you. Same-day, evening & weekend appointments. Certified, fast, reliable. Call Notary Cincy now.'
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="Cincinnati mobile notary, notary near me Cincinnati, same day notary Cincinnati, 24 hour notary Cincinnati, traveling notary Cincinnati" />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" href="/images/favicon.png" type="image/png" />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Notary Cincy",
    "image": "https://www.notarycincy.com/images/logo.png",
    "telephone": "+15135550188",
    "priceRange": "$$",
    "address": { "@type": "PostalAddress", "addressLocality": "Cincinnati", "addressRegion": "OH", "addressCountry": "US" },
    "areaServed": ["Cincinnati","Norwood","Oakley","Hyde Park","Clifton","West Chester"],
    "openingHours": "Mo-Su 07:00-22:00",
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5.0", "reviewCount": "127" }
  })}</script>

  <style is:global>
    @import '@fontsource/playfair-display/400.css';
    @import '@fontsource/playfair-display/600.css';
    @import '@fontsource/playfair-display/700.css';
    @import '@fontsource/inter/400.css';
    @import '@fontsource/inter/500.css';
    @import '@fontsource/inter/600.css';
    @import '@fontsource/inter/700.css';

    :root {
      /* Exact oklch values from computed styles */
      --foreground:   #17202e;   /* oklch(0.18 0.04 260) */
      --primary:      #1e2d4a;   /* oklch(0.24 0.07 260) */
      --primary-deep: #0e1826;   /* oklch(0.18 0.06 260) */
      --primary-fg:   #f8f9fb;   /* oklch(0.99 0.005 250) */
      --gold:         #d4aa25;   /* oklch(0.78 0.14 80) */
      --gold-deep:    #b08a16;   /* oklch(0.65 0.14 75) */
      --background:   #ffffff;
      --card:         #ffffff;
      --secondary:    #f1f4f8;   /* oklch(0.97 0.01 250) */
      --muted-fg:     #6b7a8d;   /* oklch(0.50 0.03 257) */
      --border:       #e5e8ef;   /* oklch(0.929 0.013 255) */
      --font-serif:   'Playfair Display', Georgia, serif;
      --font-sans:    'Inter', system-ui, -apple-system, sans-serif;
      --radius:       0.625rem;
      --radius-2xl:   1rem;
      --radius-3xl:   1.5rem;
      --max-w:        72rem; /* max-w-6xl = 1152px */
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
    body { font-family: var(--font-sans); background: var(--background); color: var(--foreground); line-height: 1.5; font-size: 16px; }
    img { max-width: 100%; height: auto; display: block; }
    a { color: inherit; text-decoration: none; }
    button { font-family: inherit; cursor: pointer; border: none; background: none; }
    ul, ol { padding: 0; list-style: none; }
    strong { font-weight: 600; }

    .container { width: 100%; max-width: var(--max-w); margin-inline: auto; padding-inline: 1rem; }

    /* Typography */
    h1, h2, h3 { font-family: var(--font-serif); line-height: 1.15; font-weight: 700; }
    h1 { font-size: clamp(2.25rem, 6vw, 4.5rem); letter-spacing: -0.025em; }
    h2 { font-size: clamp(1.875rem, 4vw, 3rem); letter-spacing: -0.02em; line-height: 1.2; }
    h3 { font-size: 1.125rem; font-weight: 600; }
    p { color: var(--muted-fg); line-height: 1.75; }

    /* Section labels */
    .label { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gold); }

    /* Buttons — rounded-full with Inter font */
    .btn { display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 1rem 1.75rem; border-radius: 999px; font-family: var(--font-sans); font-weight: 600; font-size: 1rem; transition: all 0.2s; cursor: pointer; border: 2px solid transparent; white-space: nowrap; }
    .btn-sm { padding: 0.75rem 1.75rem; font-size: 0.875rem; }
    .btn-gold { background: var(--gold); color: var(--primary-deep); border-color: var(--gold); box-shadow: 0 4px 20px rgba(212,170,37,0.4); }
    .btn-gold:hover { background: #e0b82a; transform: scale(1.02); }
    .btn-white-outline { background: rgba(255,255,255,0.05); color: #fff; border-color: rgba(255,255,255,0.8); backdrop-filter: blur(4px); }
    .btn-white-outline:hover { background: #fff; color: var(--primary-deep); }
    .btn-primary { background: var(--primary); color: var(--primary-fg); }
    .btn-primary:hover { opacity: 0.9; }

    /* Sections */
    .section { padding-block: 5rem; }
    @media (min-width: 768px) { .section { padding-block: 7rem; } }
    .bg-white   { background: var(--background); }
    .bg-secondary { background: var(--secondary); }
    .bg-primary-dark { background: var(--primary); color: var(--primary-fg); }
    .bg-hero-dark { background: linear-gradient(to bottom, rgba(14,24,38,0.92) 0%, rgba(30,45,74,0.7) 40%, rgba(14,24,38,0.95) 100%), var(--primary-deep); }

    /* Cards */
    .card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius-2xl); transition: all 0.2s; }
    .card-hover:hover { transform: translateY(-4px); border-color: rgba(212,170,37,0.6); box-shadow: 0 10px 40px rgba(30,45,74,0.12); }

    /* Nav */
    .nav { position: sticky; top: 0; z-index: 40; width: 100%; border-bottom: 1px solid rgba(229,232,239,0.6); background: rgba(255,255,255,0.85); backdrop-filter: blur(12px); height: 5rem; display: flex; align-items: center; }
    .nav-inner { display: flex; width: 100%; max-width: var(--max-w); margin-inline: auto; padding-inline: 1rem; align-items: center; justify-content: space-between; }
    .nav-logo img { height: 3rem; width: auto; }
    .nav-links { display: none; }
    @media (min-width: 768px) {
      .nav-links { display: flex; align-items: center; gap: 1.75rem; font-size: 0.875rem; font-weight: 500; }
      .nav-links a { color: var(--foreground); transition: color 0.15s; }
      .nav-links a:hover { color: var(--primary); }
    }
    .nav-actions { display: flex; align-items: center; gap: 0.75rem; }
    .nav-phone { font-size: 0.875rem; font-weight: 600; color: var(--primary); display: none; }
    @media (min-width: 640px) { .nav-phone { display: block; } }
    .nav-mobile-toggle { display: flex; padding: 0.5rem; color: var(--foreground); }
    @media (min-width: 768px) { .nav-mobile-toggle { display: none; } }

    /* Mobile nav drawer */
    .nav-mobile { display: none; position: absolute; top: 5rem; left: 0; right: 0; background: #fff; border-bottom: 1px solid var(--border); padding: 1rem; flex-direction: column; gap: 0.25rem; box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
    .nav-mobile.open { display: flex; }
    .nav-mobile a { padding: 0.75rem 1rem; font-size: 0.9375rem; font-weight: 500; border-radius: var(--radius); color: var(--foreground); transition: background 0.15s, color 0.15s; }
    .nav-mobile a:hover { background: var(--secondary); color: var(--primary); }
  </style>
</head>
<body>
  <slot />
  <script>
    const toggle = document.getElementById('nav-toggle');
    const drawer = document.getElementById('nav-mobile');
    if (toggle && drawer) {
      toggle.addEventListener('click', () => {
        drawer.classList.toggle('open');
        toggle.setAttribute('aria-expanded', drawer.classList.contains('open') ? 'true' : 'false');
      });
    }
  </script>
</body>
</html>
