---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Appointment Requested | Notary Cincy" description="Thanks for booking with Notary Cincy. We'll confirm your appointment shortly.">
  <main style="min-height:80vh;display:flex;align-items:center">
    <div class="container" style="text-align:center;padding-block:5rem">
      <div style="width:72px;height:72px;background:rgba(212,168,32,0.15);border:2px solid var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;font-size:2rem">✓</div>
      <h1 style="color:var(--white);font-size:clamp(1.75rem,4vw,2.5rem);margin-bottom:1rem">Request Received!</h1>
      <p style="max-width:480px;margin-inline:auto">We've received your appointment request and will confirm within minutes. For immediate service call <a href="tel:+15135550188" style="color:var(--gold);font-weight:700">(513) 555-0188</a>.</p>
      <a href="/" class="btn btn-gold" style="margin-top:2rem">Back to Home</a>
    </div>
  </main>
</Layout>
