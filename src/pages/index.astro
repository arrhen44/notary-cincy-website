---
import Layout from '../layouts/Layout.astro';

const services = [
  { icon: 'file', title: 'General Notarizations', desc: 'Affordable notary for everyday documents and forms.' },
  { icon: 'home', title: 'Real Estate Closings', desc: 'On-site signing for buyers, sellers, and refinances.' },
  { icon: 'briefcase', title: 'Loan Signings', desc: 'Certified loan signing agent for lenders and borrowers.' },
  { icon: 'scroll', title: 'Power of Attorney', desc: 'Notarize POA documents quickly and securely.' },
  { icon: 'pen', title: 'Affidavits', desc: 'Sworn statements notarized on demand.' },
  { icon: 'heart', title: 'Hospital / Jail Visits', desc: "Compassionate notary visits when you can't travel." },
];

const steps = [
  { num: '01', title: 'Call or Book Online', desc: 'Reach us by phone or our quick form. We confirm in minutes.' },
  { num: '02', title: 'We Travel to Your Location', desc: 'Home, office, hospital, café — anywhere in Greater Cincinnati.' },
  { num: '03', title: 'Get Your Documents Notarized', desc: 'Fast, professional, and done right the first time.' },
];

const reviews = [
  { text: 'Fast, professional, and came right to my house in Cincinnati. Highly recommend.', name: 'Sarah M.', location: 'Hyde Park' },
  { text: 'Needed a notary on a Sunday evening — they showed up in under an hour. Lifesaver.', name: 'James R.', location: 'Norwood' },
  { text: 'Super easy booking and very professional. Will use again for our next closing.', name: 'Priya K.', location: 'Oakley' },
  { text: 'Came to the hospital to notarize POA for my dad. Kind and quick. Thank you.', name: 'Michael T.', location: 'Downtown Cincinnati' },
  { text: 'Same-day, fair price, and zero hassle. Best mobile notary in Cincinnati.', name: 'Ashley B.', location: 'Clifton' },
];

const areas = [
  'Downtown Cincinnati','Norwood','Oakley','Hyde Park','Clifton',
  'West Chester','Mason','Blue Ash','Mt. Lookout','Northside',
  'Anderson Township','Loveland',
];

const faqs = [
  { q: 'Do you offer same-day notary services in Cincinnati?', a: 'Yes. We offer same-day mobile notary appointments across Cincinnati, often within an hour. Just call us.' },
  { q: 'How much does a mobile notary cost?', a: 'Our services start at $25 per notarized signature. A travel fee may apply depending on your location. Contact us for an exact quote.' },
  { q: 'What do I need for notarization?', a: "You'll need a valid, unexpired government-issued photo ID (driver's license, passport, or state ID) and the unsigned document you need notarized." },
  { q: 'Do you travel to hospitals or homes?', a: "Yes. We make compassionate visits to hospitals, care facilities, and private residences. Just let us know your location and we'll come to you." },
  { q: 'Are you available evenings and weekends?', a: 'Absolutely — we offer 7-day-a-week service including evenings, with 24-hour notary available on request.' },
];
---
<Layout title="Cincinnati Mobile Notary | Same-Day & 24 Hour Service | Notary Cincy">

  <!-- ── Sticky Header ── -->
  <header style="position:relative">
    <nav class="nav">
      <div class="nav-inner">
        <a href="#top" class="nav-logo" aria-label="Notary Cincy">
          <img src="/images/logo.png" alt="Notary Cincy logo" width="240" height="48" />
        </a>

        <div class="nav-links">
          <a href="#services">Services</a>
          <a href="#how">How It Works</a>
          <a href="#pricing">Pricing</a>
          <a href="#faq">FAQ</a>
          <a href="#book">Book</a>
        </div>

        <div class="nav-actions">
          <a href="tel:+15135550188" class="nav-phone">(513) 555-0188</a>
          <a href="tel:+15135550188" class="btn btn-primary btn-sm" style="border-radius:999px">Call</a>
          <button class="nav-mobile-toggle" id="nav-toggle" aria-controls="nav-mobile" aria-expanded="false" aria-label="Toggle menu">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
          </button>
        </div>
      </div>

      <!-- Mobile drawer -->
      <nav class="nav-mobile" id="nav-mobile" aria-label="Mobile navigation">
        <a href="#services">Services</a>
        <a href="#how">How It Works</a>
        <a href="#pricing">Pricing</a>
        <a href="#faq">FAQ</a>
        <a href="#book">Book</a>
        <a href="tel:+15135550188" style="color:var(--primary);font-weight:700">(513) 555-0188</a>
      </nav>
    </nav>
  </header>

  <main>

    <!-- ── Hero ── -->
    <section id="top" class="hero-section" aria-labelledby="hero-heading">
      <div class="hero-img-wrap" aria-hidden="true">
        <picture>
          <source media="(max-width:768px)" srcset="/images/hero-mobile.jpg" width="768" height="432" />
          <img src="/images/hero.jpg" alt="" width="1920" height="1080" fetchpriority="high" loading="eager" class="hero-img" />
        </picture>
      </div>
      <div class="hero-overlay" aria-hidden="true"></div>
      <div class="container hero-content">
        <div class="hero-inner">
          <!-- "Available Now" badge -->
          <span class="hero-badge">
            <span class="badge-dot" aria-hidden="true"></span>
            Available Now in Cincinnati
          </span>

          <h1 id="hero-heading">
            Cincinnati Mobile Notary —<br />
            <span style="color:var(--gold)">We Come to You</span>
          </h1>

          <p class="hero-sub">
            Same-day appointments. Available evenings and weekends. Fast, reliable, and professional notary service across Greater Cincinnati.
          </p>

          <div class="hero-cta">
            <a href="tel:+15135550188" class="btn btn-gold">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384"/></svg>
              Call Now
            </a>
            <a href="#book" class="btn btn-white-outline">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
              Book Appointment
            </a>
          </div>

          <ul class="hero-trust" aria-label="Trust indicators">
            <li>Certified Notary</li>
            <li>Same-Day Service</li>
            <li>Available 7 Days a Week</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ── Services ── (white bg) -->
    <section id="services" class="section bg-white" aria-labelledby="services-heading">
      <div class="container">
        <div class="section-header">
          <p class="label">Our Services</p>
          <h2 id="services-heading">Mobile Notary Services in Cincinnati</h2>
          <p class="section-desc">Whatever you need notarized, we handle it — at your home, office, hospital, or anywhere in the city.</p>
        </div>
        <div class="services-grid">
          {services.map((s, i) => (
            <div class="card card-hover service-card">
              <div class="service-icon-wrap" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  {i === 0 && <><path d="M14.364 13.634a2 2 0 0 0-.506.854l-.837 2.87a.5.5 0 0 0 .62.62l2.87-.837a2 2 0 0 0 .854-.506L21.378 12a1 1 0 0 0-3.004-3.004z"/><path d="M14.487 7.858A1 1 0 0 1 14 7V2"/><path d="M20 19.645V20a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l2.516 2.516"/><path d="M8 18h1"/></>}
                  {i === 1 && <><path d="M3 9a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2"/><path d="M3 11V19a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-8"/><path d="M9 22V12h6v10"/><path d="m2 5 10-3 10 3"/></>}
                  {i === 2 && <><rect width="20" height="14" x="2" y="5" rx="2"/><path d="M2 10h20"/></>}
                  {i === 3 && <><path d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/></>}
                  {i === 4 && <><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></>}
                  {i === 5 && <><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></>}
                </svg>
              </div>
              <h3>{s.title}</h3>
              <p style="font-size:0.875rem;margin-top:0.375rem">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── How It Works ── (light gray bg) -->
    <section id="how" class="section bg-secondary" aria-labelledby="how-heading">
      <div class="container">
        <div class="section-header">
          <p class="label">How It Works</p>
          <h2 id="how-heading">Three Simple Steps</h2>
        </div>
        <div class="steps-grid">
          {steps.map(s => (
            <div class="card step-card">
              <div class="step-num">{s.num}</div>
              <h3 style="margin-top:0.75rem;font-size:1.25rem">{s.title}</h3>
              <p style="margin-top:0.5rem">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Reviews ── (white bg) -->
    <section id="reviews" class="section bg-white" aria-labelledby="reviews-heading">
      <div class="container">
        <div class="section-header">
          <p class="label">Testimonials</p>
          <h2 id="reviews-heading">Trusted by Cincinnati Locals</h2>
        </div>
        <div class="reviews-grid">
          {reviews.map(r => (
            <figure class="card review-card">
              <div class="review-stars" aria-label="5 stars">
                {[...Array(5)].map(() => (
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"/></svg>
                ))}
              </div>
              <blockquote>
                <p style="color:var(--foreground);font-size:0.9375rem;margin-top:0.75rem">"{r.text}"</p>
              </blockquote>
              <figcaption style="margin-top:1.25rem;padding-top:1.25rem;border-top:1px solid var(--border);display:flex;align-items:center;gap:0.5rem;font-size:0.875rem">
                <span style="color:var(--foreground)">— {r.name},</span>
                <span style="color:var(--muted-fg)">{r.location}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Service Areas ── (dark primary bg) -->
    <section class="section bg-primary-dark" aria-labelledby="areas-heading">
      <div class="container">
        <div class="areas-grid-layout">
          <div class="areas-text">
            <p class="label">Service Area</p>
            <h2 id="areas-heading" style="margin-top:0.75rem">Mobile Notary Services in Cincinnati and Surrounding Areas</h2>
            <p style="margin-top:1.25rem;color:rgba(255,255,255,0.8);line-height:1.75">As Cincinnati's go-to <strong>mobile notary</strong>, we serve the entire Greater Cincinnati metro. Our <strong>traveling notary</strong> comes to your home, office, hospital, or coffee shop — whichever is easiest for you.</p>
            <ul class="areas-list">
              {areas.map(area => (
                <li>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color:var(--gold);flex-shrink:0"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
                  {area}
                </li>
              ))}
            </ul>
          </div>
          <div class="areas-map-placeholder" aria-hidden="true">
            <div class="map-inner">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color:rgba(212,170,37,0.6)"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
              <p style="margin-top:1rem;color:rgba(255,255,255,0.5);font-size:0.875rem">Greater Cincinnati Area</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Pricing ── (white bg, centered) -->
    <section id="pricing" class="section bg-white" aria-labelledby="pricing-heading" style="text-align:center">
      <div class="container" style="max-width:56rem">
        <div class="section-header">
          <p class="label">Pricing</p>
          <h2 id="pricing-heading">Simple, Honest Pricing</h2>
        </div>
        <div class="pricing-card card" style="display:inline-block;text-align:center">
          <p style="font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted-fg)">Mobile Notary Visits</p>
          <p class="pricing-amount" style="margin-top:0.75rem">Starting at <span style="color:var(--gold)">$25</span></p>
          <p style="margin-top:1rem;font-size:0.9375rem">Per notarized signature. Travel fee may apply depending on distance.</p>
          <a href="tel:+15135550188" class="btn btn-primary" style="margin-top:1.75rem;border-radius:999px">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384"/></svg>
            Get a Quote
          </a>
        </div>
      </div>
    </section>

    <!-- ── FAQ ── (light gray bg) -->
    <section id="faq" class="section bg-secondary" aria-labelledby="faq-heading">
      <div class="container" style="max-width:48rem">
        <div class="section-header">
          <p class="label">FAQ</p>
          <h2 id="faq-heading">Frequently Asked Questions</h2>
        </div>
        <div class="faq-list">
          {faqs.map((f, i) => (
            <details class="faq-item" open={i === 0 ? true : undefined}>
              <summary>
                <span>{f.q}</span>
                <svg class="faq-chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
              </summary>
              <div class="faq-answer">{f.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Book ── (white bg) -->
    <section id="book" class="section bg-white" aria-labelledby="book-heading">
      <div class="container" style="max-width:48rem">
        <div class="section-header">
          <p class="label">Book Now</p>
          <h2 id="book-heading">Schedule Your Notary Appointment</h2>
          <p class="section-desc">Same-day appointments available — we typically respond within minutes.</p>
        </div>
        <form class="card book-form" action="https://formspree.io/f/xjkwrbvl" method="POST" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label for="name">Name</label>
              <input id="name" type="text" name="name" required autocomplete="name" />
            </div>
            <div class="form-group">
              <label for="phone">Phone</label>
              <input id="phone" type="tel" name="phone" required autocomplete="tel" />
            </div>
          </div>
          <div class="form-group">
            <label for="location">Location (City / Address)</label>
            <input id="location" type="text" name="location" required />
          </div>
          <div class="form-group">
            <label for="service">Document Type</label>
            <select id="service" name="service" required>
              <option value="">Select a service…</option>
              <option>General Notarizations</option>
              <option>Real Estate Closings</option>
              <option>Loan Signings</option>
              <option>Power of Attorney</option>
              <option>Affidavits</option>
              <option>Hospital / Jail Visits</option>
            </select>
          </div>
          <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
          <input type="hidden" name="_subject" value="New Notary Appointment Request — Notary Cincy" />
          <input type="hidden" name="_next" value="https://www.notarycincy.com/thank-you" />
          <button type="submit" class="btn btn-primary" style="width:100%;margin-top:0.5rem;border-radius:999px;font-size:1rem;padding:1rem">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
            Request Appointment
          </button>
          <p style="text-align:center;margin-top:1rem;font-size:0.875rem;color:var(--muted-fg)">
            Or call <a href="tel:+15135550188" style="color:var(--primary);font-weight:600">(513) 555-0188</a> for immediate service.
          </p>
        </form>
      </div>
    </section>

    <!-- ── Footer CTA ── (dark hero bg) -->
    <section class="section bg-hero-dark footer-cta" aria-labelledby="cta-heading">
      <div class="container" style="text-align:center">
        <h2 id="cta-heading" style="color:#fff">Need a Notary in Cincinnati <span style="color:var(--gold)">Today?</span></h2>
        <p style="margin-top:1.25rem;font-size:1.125rem;color:rgba(255,255,255,0.85);max-width:42rem;margin-inline:auto">We're available now. Call or book — we'll be at your door fast.</p>
        <div class="cta-actions">
          <a href="tel:+15135550188" class="btn btn-gold">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384"/></svg>
            Call Now
          </a>
          <a href="#book" class="btn btn-white-outline">Book Appointment</a>
        </div>
      </div>
    </section>

  </main>

  <!-- ── Footer ── (white bg) -->
  <footer class="site-footer">
    <div class="container footer-inner">
      <div style="display:flex;align-items:center;gap:0.5rem">
        <img src="/images/logo.png" alt="Notary Cincy" height="28" width="auto" style="height:1.75rem;width:auto;opacity:0.8" loading="lazy" />
      </div>
      <p>&copy; {new Date().getFullYear()} Notary Cincy — Mobile Notary serving Greater Cincinnati, OH</p>
      <a href="tel:+15135550188" style="font-weight:600;color:var(--primary)">(513) 555-0188</a>
    </div>
  </footer>

</Layout>

<style>
  /* ── Hero ── */
  .hero-section { position: relative; overflow: hidden; background: var(--primary-deep); color: #fff; }
  .hero-img-wrap { position: absolute; inset: 0; z-index: 0; }
  .hero-img-wrap picture { display: contents; }
  .hero-img { width: 100%; height: 100%; object-fit: cover; opacity: 0.25; }
  .hero-overlay { position: absolute; inset: 0; z-index: 1; background: linear-gradient(to bottom, rgba(14,24,38,0.6) 0%, rgba(30,45,74,0.4) 40%, rgba(14,24,38,0.9) 100%); }
  .hero-content { position: relative; z-index: 2; padding-block: 5rem 5rem; }
  @media (min-width: 768px) { .hero-content { padding-block: 8rem; } }
  .hero-inner { max-width: 48rem; }
  .hero-badge { display: inline-flex; align-items: center; gap: 0.5rem; border-radius: 999px; border: 1px solid rgba(212,170,37,0.4); background: rgba(255,255,255,0.05); padding: 0.25rem 0.75rem; font-size: 0.75rem; font-weight: 500; letter-spacing: 0.075em; text-transform: uppercase; color: var(--gold); }
  .badge-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--gold); animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.35; } }
  .hero-section h1 { margin-top: 1.5rem; color: #fff; line-height: 1.05; letter-spacing: -0.025em; }
  .hero-sub { margin-top: 1.5rem; font-size: clamp(1rem, 2vw, 1.25rem); color: rgba(255,255,255,0.85); max-width: 42rem; }
  .hero-cta { margin-top: 2rem; display: flex; flex-wrap: wrap; gap: 0.75rem; }
  .hero-trust { margin-top: 2.5rem; display: flex; flex-wrap: wrap; gap: 1.5rem; padding: 0; }
  .hero-trust li { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; color: rgba(255,255,255,0.65); font-weight: 500; }
  .hero-trust li::before { content: '✓'; color: var(--gold); font-weight: 700; }

  /* ── Shared section header ── */
  .section-header { text-align: center; margin-bottom: 3rem; }
  .section-header h2 { margin-top: 0.75rem; color: var(--foreground); }
